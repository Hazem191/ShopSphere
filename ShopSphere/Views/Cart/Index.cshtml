@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model List<CartItemVM>
@{
    ViewData["Title"] = Localizer["سلة التسوق"];
    var total = Model.Sum(x => x.LineTotal);
    var isRTL = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");
}

<style>
    .cart-img { width: 90px; height: 90px; object-fit: cover; border-radius: 16px; box-shadow: var(--shadow-sm); }
    .cart-img-placeholder { width: 90px; height: 90px; border-radius: 16px; background: linear-gradient(135deg, var(--border-color), var(--bg-color)); display:flex; align-items:center; justify-content:center; }
    
    .qty-box { background: var(--bg-color); border-radius: 30px; padding: 4px; border: 1px solid var(--border-color); display: inline-flex; align-items: center; }
    .qty-btn { width: 28px; height: 28px; border-radius: 50% !important; border: none !important; display: flex; align-items: center; justify-content: center; background: var(--card-bg) !important; color: var(--text-color) !important; box-shadow: var(--shadow-sm); transition: 0.2s; }
    .qty-btn:hover { background: var(--primary-color) !important; color: #fff !important; transform: scale(1.1); }
    
    .btn-accent { 
        background: var(--accent-color) !important; 
        color: #fff !important; 
        border: none !important;
        transition: 0.3s;
    }
    .btn-accent:hover { 
        background: var(--accent-hover) !important; 
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(34, 197, 94, 0.3);
    }
    
    .cart-row { transition: 0.3s; border-radius: 20px; margin-bottom: 10px; border: 1px solid transparent; }
    .cart-row:hover { background: var(--card-bg); border-color: var(--border-color); box-shadow: var(--shadow-md); }
    
    .remove-link { color: #ef4444; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
    .remove-link:hover { background: #fee2e2; transform: rotate(90deg); }

    .summary-card { position: sticky; top: 100px; border-radius: 24px; border: none; background: var(--card-bg); box-shadow: var(--shadow-md); overflow: hidden; }
    .summary-header { background: var(--primary-color); color: #fff; padding: 20px; }
</style>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title mb-0">
            <i class="fas fa-shopping-bag me-2"></i> @Localizer["سلة التسوق"]
        </h2>
        @if (Model.Any())
        {
            <a asp-action="Clear" class="text-danger text-decoration-none small fw-bold" onclick="return confirm('@Localizer["هل تريد إفراغ سلة التسوق بالكامل؟"]')">
                <i class="fas fa-trash-alt me-1"></i> @Localizer["إفراغ السلة"]
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-4 mx-auto" style="background: var(--border-color); width:140px; height:140px; border-radius:50%; display:flex; align-items:center; justify-content:center;">
                <i class="fas fa-shopping-cart fa-4x opacity-25"></i>
            </div>
            <h3 class="fw-bold">@Localizer["السلة فارغة"]</h3>
            <p class="text-muted mb-4">@Localizer["يبدو أنك لم تضف أي منتج بعد، ابدأ التسوق الآن!"]</p>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow">
                <i class="fas fa-store @(isRTL ? "ms-2" : "me-2")"></i> @Localizer["تصفح المنتجات"]
            </a>
        </div>
    }
    else
    {
        <div class="row g-4 @(isRTL ? "flex-row-reverse" : "")">
            <!-- Items List -->
            <div class="col-lg-8">
                <div class="pe-lg-3">
                    @foreach (var item in Model)
                    {
                        <div class="cart-row bg-white bg-opacity-50 p-3 d-flex align-items-center gap-3 mb-3 border" id="row-@item.ProductId">
                            <!-- Image -->
                            <div class="flex-shrink-0">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" class="cart-img" alt="@item.ProductName" />
                                }
                                else
                                {
                                    <div class="cart-img-placeholder">
                                        <i class="fas fa-image fa-2x opacity-25"></i>
                                    </div>
                                }
                            </div>

                            <!-- Info -->
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-1">@item.ProductName</h5>
                                <div class="text-primary fw-bold">@item.Price.ToString("N2") @Localizer["ج.م"]</div>
                            </div>

                            <!-- Qty -->
                            <div class="qty-box">
                                <button type="button" onclick="updateQty(@item.ProductId, -1)" class="qty-btn">
                                    <i class="fas fa-minus small"></i>
                                </button>
                                <span class="fw-bold px-3" id="qty-@item.ProductId" style="min-width: 40px; text-align: center;">@item.Quantity</span>
                                <button type="button" onclick="updateQty(@item.ProductId, 1)" class="qty-btn">
                                    <i class="fas fa-plus small"></i>
                                </button>
                            </div>

                            <!-- Total -->
                            <div class="text-end" style="min-width: 120px;">
                                <div class="small text-muted mb-1">@Localizer["الإجمالي"]</div>
                                <div class="fw-bold fs-5 text-primary" id="line-@item.ProductId">@item.LineTotal.ToString("N2") @Localizer["ج.م"]</div>
                            </div>

                            <!-- Remove -->
                            <div class="ms-2">
                                <button type="button" onclick="removeItem(@item.ProductId)" 
                                        class="btn remove-link border-0 bg-transparent p-0">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>
                    }

                    <div class="mt-4">
                        <a asp-controller="Catalog" asp-action="Index" class="text-muted text-decoration-none fw-bold">
                            <i class="fas fa-@(isRTL ? "arrow-right" : "arrow-left") me-2"></i> @Localizer["العودة للتسوق"]
                        </a>
                    </div>
                </div>
            </div>

            <!-- Summary -->
            <div class="col-lg-4">
                <div class="card summary-card">
                    <div class="summary-header">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-receipt me-2"></i> @Localizer["ملخص الطلب"]</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-3 text-muted">
                            <span>@Localizer["عدد المنتجات"]</span>
                            <span id="total-items" class="fw-bold text-dark">@Model.Sum(x => x.Quantity)</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 text-muted">
                            <span>@Localizer["الشحن"]</span>
                            <span class="text-success fw-bold">@Localizer["مجاني"]</span>
                        </div>
                        
                        <div class="p-3 rounded-4 mb-4" style="background: var(--bg-color); border: 1px dashed var(--border-color);">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold">@Localizer["الإجمالي النهائي"]</span>
                                <span class="fs-4 fw-bold text-primary" id="grand-total">@total.ToString("N2") @Localizer["ج.م"]</span>
                            </div>
                        </div>

                        <a asp-controller="Orders" asp-action="Checkout" class="btn btn-accent w-100 py-3 rounded-pill fw-bold shadow-lg">
                            @Localizer["إتمام الدفع"] <i class="fas fa-@(isRTL ? "arrow-left" : "arrow-right") ms-2"></i>
                        </a>
                        
                        <div class="mt-4 text-center">
                            <span class="text-muted small"><i class="fas fa-shield-alt me-1 text-success"></i> @Localizer["دفع آمن 100%"]</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    const currency = '@Localizer["ج.م"]';
    const itemsLabel = '@Localizer["منتج"]';

    function updateQty(productId, delta) {
        fetch(`/Cart/UpdateQty?productId=${productId}&delta=${delta}`, {
            method: 'GET',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            if (!data.success) return;

            if (data.newQty <= 0) {
                document.getElementById('row-' + productId)?.remove();
                if (data.totalItems === 0) location.reload(); 
                return;
            }

            document.getElementById('qty-' + productId).textContent = data.newQty;
            document.getElementById('line-' + productId).innerHTML = data.newLineTotal.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' ' + currency;
            document.getElementById('grand-total').innerHTML = data.grandTotal.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' ' + currency;
            document.getElementById('total-items').textContent = data.totalItems + ' ' + itemsLabel;
            
            updateBadge(data.totalItems);
        });
    }

    function updateBadge(count) {
        const badges = document.querySelectorAll('.cart-count-badge');
        badges.forEach(badge => {
            badge.innerText = count;
            badge.style.display = count > 0 ? '' : 'none';
        });
    }

    function removeItem(productId) {
        if (!confirm('@Localizer["هل تريد حذف هذا المنتج من السلة؟"]')) return;

        fetch(`/Cart/Remove?productId=${productId}`, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const row = document.getElementById('row-' + productId);
                row.style.opacity = '0';
                row.style.transform = 'translateX(20px)';
                setTimeout(() => {
                    row.remove();
                    if (data.totalItems === 0) {
                        location.reload();
                    } else {
                        document.getElementById('grand-total').innerHTML = data.grandTotal?.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' ' + currency;
                        document.getElementById('total-items').textContent = data.totalItems;
                        updateBadge(data.totalItems);
                    }
                }, 300);
            }
        });
    }
</script>
@Html.AntiForgeryToken()
}
